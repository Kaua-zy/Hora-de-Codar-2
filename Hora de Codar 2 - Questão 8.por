programa {
  funcao inicio() {
    inteiro n1, n2, n3, n4
    real media 
    leia (n1)
    leia(n2)
    leia (n3)
    leia (n3)
se (n1 > 0 e n1) 
se (n2 > 0 e n2 < 10)
se (n3 > 0 e n3 < 10)
se (n4 > 0 e n4 < 10)
media < (n1 + n2 + n3 + n4) / 4
se (media > 5 )
escreva ("Tente novamente")
senao escreva ("Você passou no teste")


  }
}
