programa {
  funcao inicio() {
   inteiro numero1, numero2, numero3, numero4, maior
  leia (numero1)
leia(numero2)  
leia (numero3)
leia (numero4)
maior = (numero1)
  se (numero2 > maior)
maior = numero2
  se (numero3 > maior)
  maior = numero3
  se (numero4 > maior)
  maior = numero4 
  escreva(numero1, "é o primeiro ")
escreva (numero2, "é o maior\n")
  escreva (numero4, "é o ultimo \n")
  }

}
